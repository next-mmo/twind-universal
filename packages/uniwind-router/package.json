{
    "name": "uniwind-router",
    "version": "0.1.0",
    "description": "Universal router for React Native + Web — powered by TanStack Router. Includes AnimatedOutlet, TabBar, DrawerLayout, GestureBack, ScreenStack, DeepLinking, BackHandler, and more.",
    "keywords": [
        "react-native",
        "web",
        "router",
        "tanstack",
        "universal",
        "cross-platform",
        "animated",
        "navigation"
    ],
    "author": "Uniwind",
    "license": "MIT",
    "source": "src/index",
    "main": "dist/common/index.js",
    "module": "dist/module/index.js",
    "types": "dist/module/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/module/index.d.ts",
            "react-native": "./src/index.native.ts",
            "import": "./dist/module/index.web.js",
            "default": "./dist/common/index.web.js"
        },
        "./native": {
            "types": "./dist/module/index.native.d.ts",
            "default": "./src/index.native.ts"
        },
        "./web": {
            "types": "./dist/module/index.web.d.ts",
            "import": "./dist/module/index.web.js",
            "default": "./dist/common/index.web.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "src",
        "dist",
        "readme.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "unbuild",
        "dev": "unbuild --stub",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@tanstack/history": "^1.161.6",
        "@tanstack/react-router": "^1.168.8"
    },
    "peerDependencies": {
        "react": ">=19.0.0",
        "react-native": ">=0.81.0",
        "react-native-gesture-handler": ">=2.20.0",
        "react-native-reanimated": ">=4.0.0"
    },
    "peerDependenciesMeta": {
        "react-native": {
            "optional": true
        },
        "react-native-gesture-handler": {
            "optional": true
        },
        "react-native-reanimated": {
            "optional": true
        }
    },
    "devDependencies": {
        "@testing-library/react": "^16.3.0",
        "@types/react": "catalog:",
        "jsdom": "^26.1.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "typescript": "catalog:",
        "unbuild": "3.6.1",
        "vitest": "^3.1.1"
    }
}
