{
    "name": "uniwind-router-tools",
    "version": "0.0.1",
    "description": "CLI tooling for generating and watching shared TanStack Router trees in Uniwind apps",
    "repository": {
        "type": "git",
        "url": "https://github.com/next-mmo/twind-universal.git",
        "directory": "packages/uniwind-router-tools"
    },
    "bin": {
        "uniwind-route-watch": "./bin/uniwind-route-watch.mjs"
    },
    "main": "./src/cli.ts",
    "files": [
        "bin",
        "src",
        "README.md",
        "tsconfig.json"
    ],
    "engines": {
        "node": ">=20"
    },
    "scripts": {
