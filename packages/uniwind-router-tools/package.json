        "test": "echo \"No tests configured\""
    },
    "dependencies": {
        "@tanstack/router-generator": "^1.166.9",
        "tsx": "^4.20.6"
    },
    "devDependencies": {
        "@types/node": "24.10.1",
        "typescript": "5.9.3"
    }
}
