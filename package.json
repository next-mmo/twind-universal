{
  "name": "uniwind-router",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "turbo build",
    "check:typescript": "turbo check:typescript",
    "dev": "turbo dev",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "check:format": "biome check",
    "precommit": "turbo precommit",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "test:todo-routes": "vitest run",
    "format": "biome check --fix",
    "circular:check": "turbo circular:check",
    "registry:build": "turbo run registry:build --filter ui",
    "skills:sync": "npx -y skills@latest add ./skills",
    "skills:list": "npx -y skills@latest list"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@playwright/test": "^1.58.2",
    "husky": "9.1.7",
    "turbo": "2.8.16",
    "typescript": "catalog:",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@9.15.2",
  "pnpm": {
    "patchedDependencies": {
      "react-native@0.83.2": "patches/react-native@0.83.2.patch"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide"
    ],
    "overrides": {
      "lightningcss": "1.30.1"
    }
  }
}
