        "react": "catalog:",
        "react-native": "catalog:",
        "tailwindcss": "catalog:",
        "uniwind": "^1.5.0",
        "uniwind-router": "workspace:*",
        "uniwind-ui": "workspace:*"
    },
    "devDependencies": {
        "@babel/core": "7.28.5",
        "@types/react": "catalog:",
        "uniwind-router-tools": "workspace:*",
        "typescript": "catalog:"
    }
}
