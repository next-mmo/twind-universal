{
    "name": "todo-expo",
    "version": "1.0.0",
    "main": "index.ts",
    "private": true,
    "scripts": {
        "start": "uniwind-route-watch watch --target todo-expo -- expo start -c",
        "dev": "uniwind-route-watch watch --target todo-expo -- expo start -c",
        "android": "uniwind-route-watch watch --target todo-expo -- expo start --android",
