{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "moduleResolution": "bundler",
        "moduleSuffixes": [".native", ""],
        "paths": {
            "@todo/*": ["../../packages/todo-universal/*"],
            "@todo-universal/*": ["../../packages/todo-universal/*"],
            "uniwind-router": ["../../packages/uniwind-router/src/index.native.ts"],
            "ui": ["../../packages/ui/src/index.ts"],
            "ui/*": ["../../packages/ui/src/*"]
        }
    },
    "include": ["**/*.ts", "**/*.tsx", "../../packages/ui/src/**/*.d.ts"]
}
