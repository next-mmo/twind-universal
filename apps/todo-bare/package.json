{
    "name": "todo-bare",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "android": "uniwind-route-watch generate --target todo-bare -- react-native run-android --active-arch-only",
        "ios": "react-native run-ios",
        "routes:generate": "uniwind-route-watch generate --target todo-bare",
        "routes:watch": "uniwind-route-watch watch --target todo-bare",
        "start": "uniwind-route-watch watch --target todo-bare -- react-native start"
    },
    "dependencies": {
        "@gorhom/bottom-sheet": "*",
        "@tanstack/react-router": "^1.166.8",
        "call-ui": "workspace:*",
        "heroui-native": "*",
        "react": "catalog:",
        "react-native": "catalog:",
        "react-native-gesture-handler": "*",
        "react-native-reanimated": "*",
        "react-native-safe-area-context": "*",
        "react-native-screens": "*",
        "react-native-svg": "*",
        "react-native-worklets": "*",
        "uniwind": "^1.5.0",
        "uniwind-router": "workspace:*",
        "uniwind-ui": "workspace:*"
    },
    "devDependencies": {
        "@babel/core": "7.25.2",
        "@babel/preset-env": "7.25.3",
        "@babel/runtime": "7.25.0",
        "@react-native-community/cli": "20.0.2",
        "@react-native-community/cli-platform-android": "20.0.2",
        "@react-native-community/cli-platform-ios": "20.0.2",
        "@react-native/babel-preset": "0.82.1",
        "@react-native/metro-config": "0.82.1",
        "@react-native/typescript-config": "0.82.1",
        "@types/react": "catalog:",
        "uniwind-router-tools": "workspace:*",
        "typescript": "catalog:"
    },
    "engines": {
        "node": ">=20"
    }
}
