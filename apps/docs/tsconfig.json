{
    "include": ["**/*.ts", "**/*.tsx", "../../packages/ui/src/**/*.d.ts"],
    "compilerOptions": {
        "strict": true,
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        "types": ["vite/client"],
        "isolatedModules": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "target": "ES2022",
        "allowJs": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "collections/*": [".source/*"],
            "ui/blocks": ["../../packages/ui/src/blocks/index.tsx"],
            "ui": ["../../packages/ui/src/index.ts"],
            "ui/*": ["../../packages/ui/src/*"]
        },
        "noEmit": true
    }
}
