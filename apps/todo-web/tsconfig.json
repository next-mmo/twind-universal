{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "moduleSuffixes": [".web", ""],
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "moduleDetection": "force",
        "noEmit": true,
        "jsx": "react-jsx",
        "strict": true,
        "skipLibCheck": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "erasableSyntaxOnly": true,
        "paths": {
            "~/*": ["./src/*"],
            "@todo/*": ["../../packages/todo-universal/*"],
            "@todo-universal/*": ["../../packages/todo-universal/*"],
            "@uniwind-ui/*": ["../../packages/uniwind-ui/src/*"],
            "uniwind-router": ["../../packages/uniwind-router/src/index.web.ts"],
            "ui": ["../../packages/ui/src/index.ts"],
            "ui/*": ["../../packages/ui/src/*"],
            "uniwind-ui": ["../../packages/uniwind-ui/src/index.ts"],
            "uniwind-ui/*": ["../../packages/uniwind-ui/src/*"]
        }
    },
    "include": ["src", "uniwind-types.d.ts", "vite.config.ts"]
}
